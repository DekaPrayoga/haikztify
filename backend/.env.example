# Spotify API credentials — get from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Frontend URL (for OAuth callback redirect + CORS)
# Local dev: http://localhost:5173
# Production: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# OAuth redirect URI — must match Spotify Dashboard
# For local: http://localhost:3001/auth/callback  
# For production: https://your-backend-url.com/auth/callback
REDIRECT_URI=http://localhost:3001/auth/callback

# Port (default 3001, Vercel/Railway will set this automatically)
PORT=3001
