<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000" />

    <!-- Top loading progress bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top"
        android:indeterminate="false"
        android:max="100"
        android:progressDrawable="@drawable/progress_bar"
        android:visibility="gone" />

    <!--
        setupView doubles as:
          1. "URL not configured" screen (WEB_URL blank)
          2. "No connection / error" overlay (tap to retry)
    -->
    <FrameLayout
        android:id="@+id/setupView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <!-- Music note emoji -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵"
                android:textSize="64sp" />

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="HaikZTIFY"
                android:textColor="#1DB954"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Dynamic status / error message — updated from code -->
            <TextView
                android:id="@+id/setupText"
                android:layout_width="280dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:lineSpacingExtra="5dp"
                android:text="URL belum dikonfigurasi.\nEdit WEB_URL di build.gradle.kts lalu rebuild APK."
                android:textColor="#B3B3B3"
                android:textSize="14sp" />

            <!-- Tap-to-retry hint (visible when used as error overlay) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="#1DB954"
                android:paddingHorizontal="24dp"
                android:paddingVertical="10dp"
                android:text="Coba Lagi"
                android:textColor="#000000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:id="@+id/retryButton" />

        </LinearLayout>
    </FrameLayout>

</FrameLayout>
